# Static-analysis profile for the hand-written firmware, leaning toward the
# MISRA-C-style discipline the spec asks for on control/ and safety/. Run it on
# our modules only (HeaderFilterRegex below); the vendored HAL/FreeRTOS/FatFs and
# CubeMX-generated code are out of scope.
Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-braces-around-statements,
  -readability-uppercase-literal-suffix,
  -readability-isolate-declaration,
  -readability-implicit-bool-conversion,
  -misc-no-recursion,
  -misc-include-cleaner,
  -bugprone-easily-swappable-parameters
WarningsAsErrors: ''
HeaderFilterRegex: 'Core/(control|safety|proto|app|drivers|bsp)/.*'
FormatStyle: file
